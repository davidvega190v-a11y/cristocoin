<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CRISTOCOIN - EL PARAÍSO DE LOS MEMES</title>
    <style>
        @import url('https://fonts.googleapis.com');

        body {
            background-color: #000;
            background-image: url('https://www.transparenttextures.com'); /* Fondo de estrellas */
            color: #fff;
            font-family: 'Comic Neue', 'Comic Sans MS', cursive;
            text-align: center;
            margin: 0;
            overflow-x: hidden;
        }

        /* Título con efecto arcoíris animado */
        .rainbow-text {
            font-size: 5rem;
            background: linear-gradient(to left, violet, indigo, blue, green, yellow, orange, red);
            -webkit-background-clip: text;
            color: transparent;
            animation: rainbow 2s linear infinite;
            text-shadow: 5px 5px #000;
            margin-top: 20px;
        }

        @keyframes rainbow {
            0% { filter: hue-rotate(0deg); }
            100% { filter: hue-rotate(360deg); }
        }

        /* Botón Principal que vibra */
        .main-button {
            background: #ff00ff;
            color: #fff;
            padding: 25px 50px;
            font-size: 2rem;
            border: 5px solid #fff;
            border-radius: 15px;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
            box-shadow: 10px 10px 0px #00ffff;
            margin-bottom: 50px;
        }

        .main-button:hover {
            animation: shake 0.5s infinite;
            background: #00ffff;
            color: #ff00ff;
            box-shadow: 10px 10px 0px #ff00ff;
        }

        @keyframes shake {
            0% { transform: translate(1px, 1px) rotate(0deg); }
            10% { transform: translate(-1px, -2px) rotate(-1deg); }
            20% { transform: translate(-3px, 0px) rotate(1deg); }
            30% { transform: translate(3px, 2px) rotate(0deg); }
            40% { transform: translate(1px, -1px) rotate(1deg); }
            50% { transform: translate(-1px, 2px) rotate(-1deg); }
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            padding: 20px;
            max-width: 1200px;
            margin: 0 auto;
        }

        /* Tarjetas estilo Meme con bordes neón */
        .card {
            background: #111;
            padding: 20px;
            border-radius: 20px;
            border: 4px solid;
            transition: 0.3s;
        }

        .card:nth-child(1) { border-color: #00ff00; } /* Matecoin */
        .card:nth-child(2) { border-color: #ff0000; } /* Choricoina */
        .card:nth-child(3) { border-color: #ffff00; } /* Presidanete */
        .card:nth-child(4) { border-color: #a52a2a; } /* Shitcoin */
        .card:nth-child(5) { border-color: #0000ff; } /* Tucancoin */
        .card:nth-child(6) { border-color: #ff00ff; } /* Proximo */

        .card:hover { transform: translateY(-10px) rotate(2deg); }

        .btn-buy {
            background: #fff;
            color: #000;
            padding: 10px;
            text-decoration: none;
            font-weight: bold;
            display: block;
            margin-top: 10px;
            border-radius: 10px;
        }

        .socials img { width: 60px; margin: 20px; transition: 0.3s; }
        .socials img:hover { transform: scale(1.5) rotate(15deg); }

    </style>
</head>
<body>

    <h1 class="rainbow-text">CRISTOCOIN</h1>
    <p style="font-size: 1.5rem;">✨ ¡LA BENDICIÓN DE LA BLOCKCHAIN! ✨</p>
    
    <a href="https://pump.fun" class="main-button">🚀 COMPRAR $CRISTO 🚀</a>

    <div class="grid">
        <div class="card">
            <h3>MATECOIN 🧉</h3>
            <p>EL AMARGO QUE TE HACE MILLONARIO</p>
            <a href="https://pump.fun" class="btn-buy">COMPRAR COMPAÑERO</a>
        </div>

        <div class="card">
            <h3>CHORICOINA 🥩</h3>
            <p>CON CHIMI O SIN CHIMI, NOS VAMOS A LA LUNA</p>
            <a href="https://pump.fun" class="btn-buy">COMPRAR CHORI</a>
        </div>

        <div class="card">
            <h3>PRESIDANETECOIN 🏛️</h3>
            <p>EL VERDADERO PODER DEL PUEBLO</p>
            <a href="https://pump.fun" class="btn-buy">COMPRAR PDC</a>
        </div>

        <div class="card">
            <h3>$MIERDACOIN 💩</h3>
            <p>HUELE FEO PERO SUBE LINDO</p>
            <a href="https://pump.fun" class="btn-buy">COMPRAR BOSTA</a>
        </div>

        <div class="card">
            <h3>TUCANCOIN 🦜</h3>
            <p>ESTA NO PICA, VUELA</p>
            <a href="https://pump.fun" class="btn-buy">COMPRAR TUCAN</a>
        </div>

        <div class="card">
            <h3>PRÓXIMO MILAGRO ⏳</h3>
            <p>¿ESTÁS LISTO PARA OTRA BENDICIÓN?</p>
            <a href="#" class="btn-buy">PROXIMAMENTE</a>
        </div>
    </div>

    <div class="socials">
        <a href="https://x.com"><img src="https://abs.twimg.com" alt="X"></a>
        <a href="https://t.me"><img src="https://telegram.org" alt="Telegram"></a>
    </div>

    <p style="padding: 50px; color: #444;">No es consejo financiero, es un asado virtual. © 2026</p>

</body>
</html>

